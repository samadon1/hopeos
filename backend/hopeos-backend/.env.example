# Database
# Local development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./hopeos.db

# Production (Neon Postgres)
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-1.aws.neon.tech/hopeos?sslmode=require

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# Debug mode
DEBUG=true
